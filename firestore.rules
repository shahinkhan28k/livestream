rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives and Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 4. Fortress Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.id == userId
        && request.resource.data.email is string
        && request.resource.data.streamKey is string;
      allow update: if isOwner(userId)
        && request.resource.data.id == existing().id
        && request.resource.data.email == existing().email
        && request.resource.data.streamKey is string;
      allow delete: if isOwner(userId);

      match /destinations/{destId} {
        allow read, write: if isOwner(userId);
      }

      match /videos/{videoId} {
        allow read, write: if isOwner(userId);
      }

      match /schedules/{scheduleId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
